{
    "name": "rollerscapes/standards",
    "description": "Rollerscapes Code Standards and QA",
    "license": "MIT",
    "type": "library",
    "keywords": [],
    "authors": [
        {
            "name": "Sebastiaan Stok",
            "email": "s.stok@rollercapes.net"
        }
    ],
    "require": {
        "php": ">=8.1",
        "jangregor/phpstan-prophecy": "^2.2",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Rollerscapes\\Standards\\": "src/"
        },
        "exclude-from-classmap": [
            "tests/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
